{
  "name": "@hushkey/hound-examples",
  "version": "0.51.0",
  "description": "Examples for @hushkey/hound",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hushkey-app/hound"
  },
  "imports": {
    "@hushkey/hound/": "../core/"
  },
  "exports": {
    "./server": "./index.ts"
  },
  "tasks": {
    "dev": "deno run -A --watch --env-file='../.env' index.ts",
    "start": "deno run -A --env-file='../.env' index.ts",
    "benchmark": "deno run -A --env-file='../.env' benchmark.ts",
    "codegen": "deno run -A plugins/codegen.plugin.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve",
    "semiColons": true
  },
  "lint": {
    "include": [
      "core/",
      "adapters/"
    ],
    "exclude": [
      "examples/"
    ],
    "rules": {
      "exclude": [
        "no-unused-vars",
        "no-explicit-any"
      ],
      "tags": [
        "recommended"
      ]
    }
  }
}
